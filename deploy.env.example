# =============================================================================
# ATAK pipeline — deploy.env
# =============================================================================
# install_linux.sh copies this file to deploy.env on first run, then ensures the
# “Defaults” block below exists so new users can install ATAK + plugin over USB
# without manual setup. Forks: change URLs or export ATAK_BUNDLE_* when running
# install_linux.sh (see that script).
#
# Optional overrides: ATAK_CIV_APK_URL + ATAK_CIV_VERSION (direct .apk link)
# take effect only if ATAK_DEPLOY_MANIFEST_URL is removed or unset.
# =============================================================================

# --- Defaults (public pipeline; ATAK version/APK path come from this JSON) ---
ATAK_DEPLOY_MANIFEST_URL=http://31.220.30.74/atak/manifest.json

# Plugin: GitHub Releases “Latest” .apk (see atak_adb_deploy.py)
ATAK_PLUGIN_GITHUB_REPO=atakmaps/TAK-UV-PRO

# --- Optional ---
# ATAK_DEPLOY_REPORT_URL=
# ATAK_DEPLOY_API_TOKEN=
# ATAK_PACKAGE_NAME=com.atakmap.app.civ

# --- Rare: direct ATAK .apk instead of manifest (uncomment and fill; clear manifest above) ---
# ATAK_CIV_APK_URL=https://example.com/atak.apk
# ATAK_CIV_VERSION=5.x.x
